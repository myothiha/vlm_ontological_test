COCO_PATH=/path/to/coco
COCO_ANNOTATION_PATH=/path/to/coco/annotations/instances_train2017.json
COCO_IMAGE_PATH=/path/to/coco/images/train2017/

# ── Local model paths ─────────────────────────────────────────────────────────
DEEP_SEEK_R1_32B=/path/to/DeepSeek-R1-Distill-Qwen-32B
DEEP_SEEK_R1_70B=/path/to/DeepSeek-R1-Distill-Llama-70B
Llama3_OpenBioLLM_70B=/path/to/Llama3-OpenBioLLM-70B
Llama3_8B_Instruct=/path/to/Llama-3.1-8B-Instruct
Bio_GPT_Large=/path/to/BioGPT-Large
GEMMA3_27B_PATH=/path/to/gemma-3-27b-it
LLaVA=/path/to/llava-1.5-7b-hf
PathGen_LLaVA=/path/to/PathGen-LLaVA

# ── API keys ──────────────────────────────────────────────────────────────────
HF_ACCESS_TOKEN=hf_your_token_here
HF_CACHE_DIR=/path/to/huggingface_cache
OPENAI_API_KEY=sk-your_key_here
label_box_project_id=your_labelbox_project_id
label_box_dataset_id=your_labelbox_dataset_id
label_box_api_key=your_labelbox_api_key

# ── Ollama ────────────────────────────────────────────────────────────────────
# URL of the running Ollama API server (required).
ollama_host=http://localhost:11434

# GPU cooldown — pause inference when GPU temperature (°C) hits this threshold.
# Default: 80
GPU_TEMP_THRESHOLD=80

# Seconds to wait during cooldown before resuming inference.
# Default: 60
GPU_COOLDOWN_TIME=60